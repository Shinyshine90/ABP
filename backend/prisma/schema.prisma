generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  builds    Build[]

  @@map("users")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  gitUrl      String   @map("git_url")
  cloneMethod String   @default("http") @map("clone_method")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  builds      Build[]

  @@map("projects")
}

model Build {
  id         Int       @id @default(autoincrement())
  projectId  Int       @map("project_id")
  branch     String    @default("main")
  gradleTask String    @default("assembleRelease") @map("gradle_task")
  status     String    @default("pending")
  version    String?
  gitCommit  String?   @map("git_commit")
  createdBy  String?   @map("created_by")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  apkPath    String?   @map("apk_path")
  project    Project   @relation(fields: [projectId], references: [id])
  user       User?     @relation(fields: [createdBy], references: [username])
  logs       BuildLog[]

  @@map("builds")
}

model BuildLog {
  id        Int      @id @default(autoincrement())
  buildId   Int      @map("build_id")
  logType   String   @map("log_type")
  content   String
  timestamp DateTime @default(now())
  build     Build    @relation(fields: [buildId], references: [id])

  @@map("build_logs")
}
